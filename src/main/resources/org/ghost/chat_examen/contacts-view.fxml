<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.ghost.chat_examen.controllers.ContactsController"
            prefHeight="650.0" prefWidth="1000.0"
            minHeight="650.0" minWidth="1000.0"
            maxHeight="650.0" maxWidth="1000.0"
            styleClass="root-pane">

    <stylesheets>
        <URL value="@styles/contacts.css"/>
    </stylesheets>

    <!-- ═══════════════════════════════════════
         CONTENEUR PRINCIPAL CENTRÉ
    ═══════════════════════════════════════ -->
    <center>
        <StackPane styleClass="root-container">

            <!-- Fond avec dégradé qui prend tout l'espace -->
            <Region styleClass="bg-canvas-full"/>

            <!-- Conteneur centré avec taille fixe 1000x650 -->
            <HBox styleClass="content-wrapper" alignment="CENTER">

                <!-- Panneau gauche (40% - 400px) -->
                <VBox styleClass="left-slab" minWidth="400" maxWidth="400" prefWidth="400">
                    <padding><Insets top="35" bottom="35" left="25" right="25"/></padding>

                    <!-- Décoration coin supérieur gauche -->
                    <Region styleClass="corner-deco-tl" StackPane.alignment="TOP_LEFT"/>

                    <!-- Header avec monogramme et bouton déconnexion -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <padding><Insets left="5" right="5"/></padding>

                        <StackPane styleClass="mono-ring-small">
                            <Label fx:id="avatarLabel" text="A" styleClass="mono-letter-small"/>
                        </StackPane>

                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label fx:id="usernameLabel" text="UTILISATEUR" styleClass="app-name-small"/>
                            <Label text="CONTACTS · MESSAGERIE" styleClass="app-tagline-small"/>
                        </VBox>

                        <Button text="DÉCONNEXION" styleClass="btn-logout-red" onAction="#seDeconnecter"/>
                    </HBox>

                    <!-- Divider placé après le header, pas dedans -->
                    <Region styleClass="gold-divider-short" StackPane.alignment="CENTER">
                        <VBox.margin><Insets top="5" bottom="10"/></VBox.margin>
                    </Region>

                    <!-- Espacement flexible -->
                    <Region VBox.vgrow="ALWAYS" minHeight="20"/>

                    <!-- Stats -->
                    <VBox spacing="20" alignment="CENTER">
                        <Label text="MEMBRES ACTIFS" styleClass="field-label"/>

                        <HBox spacing="25" alignment="CENTER">
                            <VBox alignment="CENTER" spacing="8">
                                <Label fx:id="onlineCountLabel" text="0" styleClass="stat-number-large"/>
                                <Label text="en ligne" styleClass="badge badge-membre"/>
                            </VBox>

                            <Region styleClass="diagonal-cut-vertical" minHeight="50"/>

                            <VBox alignment="CENTER" spacing="8">
                                <Label fx:id="totalCountLabel" text="0" styleClass="stat-number-large"/>
                                <Label text="total" styleClass="badge badge-org"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Espacement flexible -->
                    <Region VBox.vgrow="ALWAYS" minHeight="20"/>

                    <!-- Rôle actuel -->
                    <VBox spacing="15" alignment="CENTER">
                        <Label text="VOTRE RÔLE" styleClass="field-label"/>
                        <Label fx:id="roleLabel" text="MEMBRE" styleClass="badge-role-large"/>

                        <Label text="Cliquez sur 💬 pour chatter"
                               styleClass="app-desc"
                               textAlignment="CENTER"
                               wrapText="true"/>
                    </VBox>

                    <!-- Décoration coin inférieur droit -->
                    <Region styleClass="corner-deco-br" StackPane.alignment="BOTTOM_RIGHT"/>
                </VBox>

                <!-- Séparateur vertical doré -->
                <Region styleClass="diagonal-cut-main"/>

                <!-- Panneau droit (60% - 600px) -->
                <VBox styleClass="right-slab" minWidth="600" maxWidth="600" prefWidth="600">

                    <!-- Onglets -->
                    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="tabs-header">
                        <padding><Insets top="20" bottom="15" left="25" right="25"/></padding>

                        <Button fx:id="tabOnline" text="EN LIGNE"
                                styleClass="tab-btn tab-active"
                                onAction="#afficherEnLigne"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

                        <Button fx:id="tabConversations" text="CONVERSATIONS"
                                styleClass="tab-btn"
                                onAction="#afficherConversations"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>

                        <Button fx:id="tabTous" text="TOUS"
                                styleClass="tab-btn"
                                onAction="#afficherTous"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>

                    <Region styleClass="sep-line">
                        <HBox.margin><Insets left="25" right="25"/></HBox.margin>
                    </Region>

                    <!-- Zone de contenu principale -->
                    <StackPane fx:id="centerPane" VBox.vgrow="ALWAYS">

                        <!-- Écran d'accueil -->
                        <VBox fx:id="welcomePane" alignment="TOP_CENTER" spacing="15"
                              styleClass="center-pane" visible="true">
                            <padding><Insets top="30" left="25" right="25" bottom="15"/></padding>

                            <Label text="👥" styleClass="welcome-icon-large"/>
                            <Label text="Mes contacts" styleClass="form-headline"/>
                            <Label text="Sélectionnez un contact pour démarrer une conversation"
                                   styleClass="form-sub" wrapText="true" textAlignment="CENTER"/>

                            <!-- Recherche -->
                            <VBox spacing="8" maxWidth="400">
                                <padding><Insets top="15"/></padding>
                                <Label text="RECHERCHER" styleClass="field-label"/>

                                <StackPane styleClass="field-frame">
                                    <TextField fx:id="searchField"
                                               promptText="Nom du contact..."
                                               styleClass="field-input-large"
                                               onKeyReleased="#filtrerMembres"/>
                                    <Label text="🔍" styleClass="field-icon-left" StackPane.alignment="CENTER_LEFT"/>
                                </StackPane>
                            </VBox>

                            <!-- Liste des membres -->
                            <VBox spacing="8" VBox.vgrow="ALWAYS" maxWidth="450">
                                <HBox alignment="CENTER" spacing="10">
                                    <Region styleClass="sep-line" HBox.hgrow="ALWAYS"/>
                                    <Label text="CONTACTS DISPONIBLES" styleClass="sep-text"/>
                                    <Region styleClass="sep-line" HBox.hgrow="ALWAYS"/>
                                </HBox>

                                <ListView fx:id="membresListView"
                                          styleClass="membres-list-large"
                                          VBox.vgrow="ALWAYS"
                                          prefHeight="260"/>
                            </VBox>
                        </VBox>

                        <!-- Zone de chat -->
                        <VBox fx:id="chatPane" styleClass="chat-zone" visible="false">

                            <!-- Header du chat -->
                            <HBox styleClass="chat-header-large" alignment="CENTER_LEFT" spacing="15">
                                <padding><Insets top="15" bottom="15" left="20" right="20"/></padding>

                                <!-- Avatar -->
                                <StackPane styleClass="avatar-circle-chat">
                                    <Label fx:id="chatAvatarLabel" text="B" styleClass="avatar-text-chat"/>
                                </StackPane>

                                <VBox HBox.hgrow="ALWAYS" spacing="3">
                                    <Label fx:id="chatDestinataireLabel" text="Contact" styleClass="chat-name-large"/>
                                    <HBox alignment="CENTER_LEFT" spacing="6">
                                        <StackPane fx:id="chatStatusDot" styleClass="status-dot-online-large"/>
                                        <Label fx:id="chatStatusLabel" text="En ligne" styleClass="status-text-large"/>
                                    </HBox>
                                </VBox>

                                <Button text="✕" styleClass="btn-close-chat" onAction="#fermerChat"/>
                            </HBox>

                            <!-- Messages -->
                            <ScrollPane fx:id="scrollPane"
                                        styleClass="messages-scroll-large"
                                        fitToWidth="true"
                                        VBox.vgrow="ALWAYS">
                                <VBox fx:id="messagesContainer"
                                      styleClass="messages-container-large"
                                      spacing="8">
                                    <padding><Insets top="15" bottom="15" left="18" right="18"/></padding>
                                </VBox>
                            </ScrollPane>

                            <!-- Zone de saisie -->
                            <HBox styleClass="input-zone-large" alignment="CENTER" spacing="12">
                                <padding><Insets top="15" bottom="15" left="20" right="20"/></padding>

                                <StackPane HBox.hgrow="ALWAYS" styleClass="field-frame-large">
                                    <TextField fx:id="messageField"
                                               promptText="Écrire un message..."
                                               styleClass="message-input-large"
                                               onAction="#envoyerMessage"/>
                                    <Label text="✎" styleClass="field-icon-left-large" StackPane.alignment="CENTER_LEFT"/>
                                </StackPane>

                                <Button text="➤" styleClass="btn-send-large" onAction="#envoyerMessage"/>
                            </HBox>
                        </VBox>
                    </StackPane>
                </VBox>
            </HBox>
        </StackPane>
    </center>

</BorderPane>